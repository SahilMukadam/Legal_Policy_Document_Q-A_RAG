# Google Gemini API Key - Get yours at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=YOUR_API_KEY

# LLM Provider (swap to "anthropic" later when ready)
LLM_PROVIDER=gemini

# App Config
APP_ENV=development
APP_PORT=8000
LOG_LEVEL=INFO

# ChromaDB
CHROMA_PERSIST_DIR=./chroma_data
CHROMA_COLLECTION_NAME=legal_docs

# Embedding Model
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Chunking Config
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
